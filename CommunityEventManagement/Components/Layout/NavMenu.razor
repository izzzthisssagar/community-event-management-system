@* The navigation menu. I use AuthorizeView so the links change depending on who is signed in:    *@
@* everyone signed in can browse events, but only an Admin sees the management links. Each link     *@
@* shows a meaningful icon from my shared Icon component so the menu reads at a glance.             *@

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="">
            <Icon Name="ticket" Size="20" /> Community Events
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <Icon Name="home" Size="18" /> Home
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                @* Links for any signed-in user. *@
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="events">
                        <Icon Name="list" Size="18" /> Browse Events
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="my-registrations">
                        <Icon Name="ticket" Size="18" /> Registrations
                    </NavLink>
                </div>

                @* Admin-only management links. *@
                <AuthorizeView Roles="Admin" Context="adminContext">
                    <div class="nav-section-label">Management</div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin" Match="NavLinkMatch.All">
                            <Icon Name="dashboard" Size="18" /> Admin Dashboard
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/events">
                            <Icon Name="calendar" Size="18" /> Manage Events
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/venues">
                            <Icon Name="map-pin" Size="18" /> Manage Venues
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/activities">
                            <Icon Name="activity" Size="18" /> Manage Activities
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/participants">
                            <Icon Name="users" Size="18" /> Manage Participants
                        </NavLink>
                    </div>
                </AuthorizeView>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>
