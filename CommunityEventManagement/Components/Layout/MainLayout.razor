@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @* Show who is signed in, plus a logout link, when there is a logged-in user. *@
            <AuthorizeView>
                <Authorized>
                    <span class="me-2 text-muted small">Signed in as <strong class="text-dark">@context.User.Identity?.Name</strong></span>
                    <a href="/auth/logout" class="btn btn-sm btn-outline-secondary"><Icon Name="log-out" Size="14" /> Log out</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn btn-sm btn-primary">Log in</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @* Everything inside the boundary is protected: if a page throws, the user sees a       *@
            @* friendly message instead of a crash.                                                 *@
            <CustomErrorBoundary>
                @Body
            </CustomErrorBoundary>
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
