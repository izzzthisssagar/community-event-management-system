@* A consistent page header used at the top of every page: a title, an optional subtitle, and an
   optional area on the right for actions (such as an "Add" button). Using one component for this
   means every page lines up the same way. *@

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-header__title">@Title</h1>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <p class="page-header__subtitle">@Subtitle</p>
        }
    </div>
    @if (Actions is not null)
    {
        <div class="page-header__actions">@Actions</div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
