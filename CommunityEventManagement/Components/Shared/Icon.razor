@* A small, reusable icon component. I keep every icon in this one place so the whole application
   uses a single, consistent set of clean line icons (and never emojis). Each icon is drawn on a
   24x24 grid and inherits the current text colour, so I can size and colour it with normal CSS. *@

<svg class="cem-icon @CssClass" width="@Size" height="@Size" viewBox="0 0 24 24" fill="none"
     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    @((MarkupString)GetInnerSvg())
</svg>

@code {
    // The name of the icon to draw, e.g. "calendar".
    [Parameter] public string Name { get; set; } = string.Empty;

    // The width and height in pixels.
    [Parameter] public int Size { get; set; } = 20;

    // An optional extra CSS class.
    [Parameter] public string? CssClass { get; set; }

    // Returns the inner SVG shapes for the requested icon. The values are fixed strings I wrote
    // myself (never user input), so rendering them as markup is safe.
    private string GetInnerSvg() => Name switch
    {
        "calendar" => "<path d='M8 2v4'/><path d='M16 2v4'/><rect width='18' height='18' x='3' y='4' rx='2'/><path d='M3 10h18'/>",
        "map-pin" => "<path d='M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z'/><circle cx='12' cy='10' r='3'/>",
        "activity" => "<path d='M22 12h-4l-3 9L9 3l-3 9H2'/>",
        "users" => "<path d='M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M22 21v-2a4 4 0 0 0-3-3.87'/><path d='M16 3.13a4 4 0 0 1 0 7.75'/>",
        "plus" => "<path d='M5 12h14'/><path d='M12 5v14'/>",
        "edit" => "<path d='M12 20h9'/><path d='M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z'/>",
        "trash" => "<path d='M3 6h18'/><path d='M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2'/>",
        "ban" => "<circle cx='12' cy='12' r='10'/><path d='m4.9 4.9 14.2 14.2'/>",
        "check-circle" => "<circle cx='12' cy='12' r='10'/><path d='m9 12 2 2 4-4'/>",
        "search" => "<circle cx='11' cy='11' r='8'/><path d='m21 21-4.3-4.3'/>",
        "clock" => "<circle cx='12' cy='12' r='10'/><polyline points='12 6 12 12 16 14'/>",
        "ticket" => "<path d='M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z'/><path d='M13 5v2'/><path d='M13 11v2'/><path d='M13 17v2'/>",
        "log-out" => "<path d='M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4'/><polyline points='16 17 21 12 16 7'/><line x1='21' x2='9' y1='12' y2='12'/>",
        "home" => "<path d='m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'/><polyline points='9 22 9 12 15 12 15 22'/>",
        "arrow-left" => "<path d='m12 19-7-7 7-7'/><path d='M19 12H5'/>",
        "inbox" => "<polyline points='22 12 16 12 14 15 10 15 8 12 2 12'/><path d='M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z'/>",
        "dashboard" => "<rect width='7' height='9' x='3' y='3' rx='1'/><rect width='7' height='5' x='14' y='3' rx='1'/><rect width='7' height='9' x='14' y='12' rx='1'/><rect width='7' height='5' x='3' y='16' rx='1'/>",
        "list" => "<line x1='8' x2='21' y1='6' y2='6'/><line x1='8' x2='21' y1='12' y2='12'/><line x1='8' x2='21' y1='18' y2='18'/><line x1='3' x2='3.01' y1='6' y2='6'/><line x1='3' x2='3.01' y1='12' y2='12'/><line x1='3' x2='3.01' y1='18' y2='18'/>",
        "mail" => "<rect width='20' height='16' x='2' y='4' rx='2'/><path d='m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7'/>",
        _ => "<circle cx='12' cy='12' r='10'/>"
    };
}
