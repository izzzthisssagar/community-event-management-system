@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]

<PageTitle>Sign in — Community Events</PageTitle>

@* This page is rendered statically (see App.razor) so the form does a normal HTTP POST to my    *@
@* AuthController at /auth/login. data-enhance="false" stops Blazor from intercepting the post.   *@

<div class="login-card">
    <div class="login-card__brand">
        <span class="login-card__badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
        </span>
        <h1 class="login-card__title">Community Events</h1>
        <p class="login-card__subtitle">Sign in to manage and join events</p>
    </div>

    @if (Registered)
    {
        <div class="alert alert-success" role="alert">
            Your account has been created — please sign in.
        </div>
    }
    @if (Error)
    {
        <div class="alert alert-danger" role="alert">
            The email or password you entered is incorrect.
        </div>
    }

    <form method="post" action="/auth/login" data-enhance="false">
        <AntiforgeryToken />

        <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input id="email" name="Email" type="email" class="form-control" placeholder="you@example.com" required autofocus />
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <div class="input-group">
                <input id="password" name="Password" type="password" class="form-control" placeholder="••••••••" required />
                <button type="button" class="btn btn-outline-secondary" id="togglePassword"
                        tabindex="-1" aria-label="Toggle password visibility">
                    <svg id="eyeOpen" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                        <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                    </svg>
                    <svg id="eyeSlash" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="display:none">
                        <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z"/>
                        <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/>
                        <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z"/>
                    </svg>
                </button>
            </div>
        </div>

        <div class="form-check mb-4">
            <input id="rememberMe" name="RememberMe" value="true" type="checkbox" class="form-check-input" />
            <label for="rememberMe" class="form-check-label">Remember me</label>
        </div>

        <button type="submit" class="btn btn-primary w-100">Sign in</button>
    </form>

    <div class="login-card__hint">
        New here? <a href="/signup">Create an account</a>
        <div class="mt-2">
            Demo admin: <strong>admin@events.com</strong> / <strong>Admin123!</strong><br />
            Demo user: <strong>user@events.com</strong> / <strong>User123!</strong>
        </div>
    </div>
</div>

@code {
    // When the login fails, my AuthController redirects back to "/login?error=true". This picks up
    // that query string value so the page can show the error message above.
    [SupplyParameterFromQuery]
    private bool Error { get; set; }

    [SupplyParameterFromQuery]
    private bool Registered { get; set; }
}

<script>
    document.getElementById('togglePassword').addEventListener('click', function () {
        var input = document.getElementById('password');
        var eyeOpen = document.getElementById('eyeOpen');
        var eyeSlash = document.getElementById('eyeSlash');
        if (input.type === 'password') {
            input.type = 'text';
            eyeOpen.style.display = 'none';
            eyeSlash.style.display = 'block';
        } else {
            input.type = 'password';
            eyeOpen.style.display = 'block';
            eyeSlash.style.display = 'none';
        }
    });
</script>
