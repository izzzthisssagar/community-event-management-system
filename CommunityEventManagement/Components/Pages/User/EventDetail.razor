@page "/events/{EventId:guid}"
@attribute [Authorize]
@using System.Security.Claims
@inject IEventService EventService
@inject IParticipantService ParticipantService
@inject IRegistrationService RegistrationService

<PageTitle>Event Details</PageTitle>

@if (_event is null)
{
    <LoadingSpinner Text="Loading event..." />
}
else
{
    <a class="btn btn-link ps-0 mb-2 d-inline-flex align-items-center gap-1" href="events">
        <Icon Name="arrow-left" Size="16" /> Back to events
    </a>

    <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
        <h1 class="mb-0">@_event.Name</h1>
        @if (_event.IsCancelled)
        {
            <StatusBadge Status="Cancelled" />
        }
    </div>

    <div class="row g-4">
        <div class="col-md-7">
            <div class="card">
                <div class="card-body p-4">
                    <p class="text-muted d-flex align-items-center gap-2 mb-1">
                        <Icon Name="calendar" Size="16" /> @_event.Date.ToString("dddd, dd MMMM yyyy")
                    </p>
                    <p class="text-muted d-flex align-items-center gap-2">
                        <Icon Name="clock" Size="16" /> @_event.StartTime.ToString(@"hh\:mm")–@_event.EndTime.ToString(@"hh\:mm")
                    </p>
                    <p class="mt-3">@_event.Description</p>

                    <h5 class="mt-4 d-flex align-items-center gap-2"><Icon Name="map-pin" Size="18" /> Venues</h5>
                    @if (_event.Venues.Count == 0)
                    {
                        <p class="text-muted">No venues assigned.</p>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (Venue venue in _event.Venues)
                            {
                                <li>@venue.Name — @venue.Address (capacity @venue.Capacity@(venue.IsAccessible ? ", accessible" : ""))</li>
                            }
                        </ul>
                    }

                    <h5 class="mt-4 d-flex align-items-center gap-2"><Icon Name="activity" Size="18" /> Activities</h5>
                    @if (_event.Activities.Count == 0)
                    {
                        <p class="text-muted">No activities assigned.</p>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (Activity activity in _event.Activities)
                            {
                                @* GetActivityDetails() is polymorphic — each subclass returns its own text. *@
                                <li>@activity.GetActivityDetails()</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card">
                <div class="card-body p-4">
                    <h5 class="card-title d-flex align-items-center gap-2"><Icon Name="ticket" Size="18" /> Registration</h5>

                    <div class="d-flex justify-content-between text-muted small mt-3 mb-3">
                        <span>Capacity: <strong class="text-dark">@_event.MaxCapacity</strong></span>
                        <span>Seats left: <strong class="text-dark">@_event.GetAvailableSeats()</strong></span>
                    </div>

                    @if (_successMessage is not null)
                    {
                        <div class="alert alert-success">@_successMessage</div>
                    }
                    @if (_errorMessage is not null)
                    {
                        <div class="alert alert-danger">@_errorMessage</div>
                    }

                    @if (_event.IsCancelled)
                    {
                        <div class="alert alert-warning mb-0">This event has been cancelled, so registration is closed.</div>
                    }
                    else if (_isAdmin)
                    {
                        @* Admins can register any participant on their behalf, so they get a picker. *@
                        <div class="mb-3">
                            <label class="form-label">Choose participant</label>
                            <select class="form-select" @bind="_selectedParticipantId">
                                <option value="@Guid.Empty">-- select --</option>
                                @foreach (Participant participant in _participants)
                                {
                                    <option value="@participant.Id">@participant.FullName (@participant.Email)</option>
                                }
                            </select>
                        </div>
                        <LoadingButton CssClass="btn btn-primary w-100" Busy="_isRegistering" OnClick="RegisterSelectedAsync">
                            <Icon Name="check-circle" Size="16" /> Register
                        </LoadingButton>
                    }
                    else if (_currentParticipant is not null)
                    {
                        @* A normal user registers themselves — no dropdown, just one button. *@
                        <p class="text-muted small mb-3">You are registering as <strong class="text-dark">@_currentParticipant.FullName</strong>.</p>
                        <LoadingButton CssClass="btn btn-primary w-100" Busy="_isRegistering" OnClick="RegisterMyselfAsync">
                            <Icon Name="check-circle" Size="16" /> Register me for this event
                        </LoadingButton>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            Your account is not linked to a participant profile, so you cannot register here.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid EventId { get; set; }

    // The signed-in user's identity is provided as a cascading value (set up in Program.cs).
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private Event? _event;
    private List<Participant> _participants = new();   // only loaded for admins (the picker)
    private Guid _selectedParticipantId = Guid.Empty;
    private string? _successMessage;
    private string? _errorMessage;
    private bool _isRegistering;

    private bool _isAdmin;
    private Participant? _currentParticipant;           // the logged-in user's own profile

    protected override async Task OnInitializedAsync()
    {
        // Work out who is signed in. An admin registers other people (a picker); a normal user
        // registers themselves, which I find by matching their email to a participant profile.
        if (AuthState is not null)
        {
            AuthenticationState authState = await AuthState;
            ClaimsPrincipal user = authState.User;
            _isAdmin = user.IsInRole("Admin");

            if (!_isAdmin)
            {
                string? sEmail = user.FindFirst(ClaimTypes.Email)?.Value;
                if (!string.IsNullOrEmpty(sEmail))
                {
                    _currentParticipant = await ParticipantService.GetByEmailAsync(sEmail);
                }
            }
        }

        if (_isAdmin)
        {
            _participants = await ParticipantService.GetAllAsync();
        }

        await LoadEventAsync();
    }

    private async Task LoadEventAsync()
    {
        _event = await EventService.GetEventByIdAsync(EventId);
    }

    // Admin path: register the participant chosen in the dropdown.
    private async Task RegisterSelectedAsync()
    {
        _successMessage = null;
        _errorMessage = null;

        if (_selectedParticipantId == Guid.Empty)
        {
            _errorMessage = "Please choose a participant first.";
            return;
        }

        await DoRegisterAsync(_selectedParticipantId);
        _selectedParticipantId = Guid.Empty;
    }

    // User path: register the logged-in user themselves.
    private async Task RegisterMyselfAsync()
    {
        _successMessage = null;
        _errorMessage = null;

        if (_currentParticipant is null)
        {
            return;
        }

        await DoRegisterAsync(_currentParticipant.Id);
    }

    // Shared registration logic for both paths.
    private async Task DoRegisterAsync(Guid guidParticipantId)
    {
        _isRegistering = true;
        try
        {
            await RegistrationService.RegisterAsync(EventId, guidParticipantId);
            _successMessage = "Registered successfully.";

            // Reload so the "seats left" number updates.
            await LoadEventAsync();
        }
        catch (EventManagementException ex)
        {
            // My custom exceptions (duplicate registration, event full, etc.) already carry a clear
            // message, so I show it gracefully here instead of letting it crash the page.
            _errorMessage = ex.Message;
        }
        finally
        {
            _isRegistering = false;
        }
    }
}
