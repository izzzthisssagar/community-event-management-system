@page "/admin/activities"
@attribute [Authorize(Roles = "Admin")]
@inject IActivityService ActivityService
@inject IJSRuntime JS
@inject IToastService ToastService

<PageTitle>Manage Activities</PageTitle>

<PageHeader Title="Activities" Subtitle="Workshops, games and talks that make up an event.">
    <Actions>
        <a class="btn btn-primary" href="admin/activities/create"><Icon Name="plus" Size="16" /> Add activity</a>
    </Actions>
</PageHeader>

@if (_activities is null)
{
    <SkeletonTable />
}
else if (_activities.Count == 0)
{
    <EmptyState IconName="activity" Message="No activities yet.">
        <Action>
            <a class="btn btn-primary" href="admin/activities/create"><Icon Name="plus" Size="16" /> Add activity</a>
        </Action>
    </EmptyState>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Duration</th>
                        <th>Details</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Activity activity in _activities)
                    {
                        <tr>
                            <td class="fw-semibold">@activity.Title</td>
                            <td><span class="badge bg-secondary">@GetActivityType(activity)</span></td>
                            <td>@activity.DurationMinutes min</td>
                            @* GetActivityDetails() is polymorphic — the correct subclass version runs. *@
                            <td class="small text-muted">@activity.GetActivityDetails()</td>
                            <td class="text-end text-nowrap">
                                <a class="btn btn-sm btn-outline-secondary" href="admin/activities/edit/@activity.Id"><Icon Name="edit" Size="14" /> Edit</a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(activity.Id, activity.Title)"><Icon Name="trash" Size="14" /> Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Activity>? _activities;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _activities = await ActivityService.GetAllAsync();
    }

    // Works out the friendly type name from the real subclass of the activity.
    private string GetActivityType(Activity activity)
    {
        return activity switch
        {
            WorkshopActivity => "Workshop",
            GameActivity => "Game",
            TalkActivity => "Talk",
            _ => "Activity"
        };
    }

    private async Task DeleteAsync(Guid guidId, string sTitle)
    {
        bool bConfirmed = await JS.InvokeAsync<bool>("confirm", $"Delete activity '{sTitle}'?");
        if (!bConfirmed)
        {
            return;
        }

        await ActivityService.DeleteAsync(guidId);
        ToastService.ShowSuccess($"Activity '{sTitle}' was deleted.");
        await LoadAsync();
    }
}
