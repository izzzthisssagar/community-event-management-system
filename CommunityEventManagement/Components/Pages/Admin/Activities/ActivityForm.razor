@page "/admin/activities/create"
@page "/admin/activities/edit/{Id:guid}"
@attribute [Authorize(Roles = "Admin")]
@inject IActivityService ActivityService
@inject NavigationManager Navigation
@inject IToastService ToastService

<PageTitle>@(IsEdit ? "Edit Activity" : "Add Activity")</PageTitle>

<PageHeader Title="@(IsEdit ? "Edit activity" : "Add activity")" Subtitle="A workshop, game or talk." />

<div class="row">
    <div class="col-lg-7 col-xl-6">
        <div class="card">
            <div class="card-body p-4">
                <EditForm Model="_model" OnValidSubmit="SaveAsync">
                    <FluentValidationValidator />
                    <ValidationSummary class="text-danger" />

                    <div class="mb-3">
                        <label class="form-label">Activity type</label>
                        @* The type can only be chosen when creating. On edit it is fixed, because a    *@
                        @* workshop cannot suddenly become a game in the Table-Per-Hierarchy design.     *@
                        <select class="form-select" @bind="_model.ActivityType" disabled="@IsEdit">
                            <option value="Workshop">Workshop</option>
                            <option value="Game">Game</option>
                            <option value="Talk">Talk</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <InputText class="form-control" @bind-Value="_model.Title" />
                        <ValidationMessage For="() => _model.Title" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Duration (minutes)</label>
                        <InputNumber class="form-control" @bind-Value="_model.DurationMinutes" />
                        <ValidationMessage For="() => _model.DurationMinutes" class="text-danger" />
                    </div>

                    @* ----- Fields that only apply to a Workshop ----- *@
                    @if (_model.ActivityType == "Workshop")
                    {
                        <div class="mb-3">
                            <label class="form-label">Instructor name</label>
                            <InputText class="form-control" @bind-Value="_model.InstructorName" />
                            <ValidationMessage For="() => _model.InstructorName" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Materials required</label>
                            <InputText class="form-control" @bind-Value="_model.MaterialsRequired" />
                            <ValidationMessage For="() => _model.MaterialsRequired" class="text-danger" />
                        </div>
                    }

                    @* ----- Fields that only apply to a Game ----- *@
                    @if (_model.ActivityType == "Game")
                    {
                        <div class="mb-3">
                            <label class="form-label">Minimum age</label>
                            <InputNumber class="form-control" @bind-Value="_model.MinimumAge" />
                            <ValidationMessage For="() => _model.MinimumAge" class="text-danger" />
                        </div>
                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" id="equipment" @bind-Value="_model.EquipmentProvided" />
                            <label class="form-check-label" for="equipment">Equipment provided</label>
                        </div>
                    }

                    @* ----- Fields that only apply to a Talk ----- *@
                    @if (_model.ActivityType == "Talk")
                    {
                        <div class="mb-3">
                            <label class="form-label">Speaker name</label>
                            <InputText class="form-control" @bind-Value="_model.SpeakerName" />
                            <ValidationMessage For="() => _model.SpeakerName" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Topic</label>
                            <InputText class="form-control" @bind-Value="_model.Topic" />
                            <ValidationMessage For="() => _model.Topic" class="text-danger" />
                        </div>
                    }

                    <div class="d-flex gap-2 mt-1">
                        <LoadingButton Type="submit" Busy="_isBusy" CssClass="btn btn-primary"><Icon Name="check-circle" Size="16" /> Save</LoadingButton>
                        <a class="btn btn-outline-secondary" href="admin/activities">Cancel</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private ActivityViewModel _model = new();
    private bool _isBusy;

    private bool IsEdit => Id.HasValue;

    protected override async Task OnInitializedAsync()
    {
        if (!IsEdit)
        {
            return;
        }

        // Load the existing activity and copy its values (including the subclass-specific ones)
        // into the form model. I use pattern matching to read the right extra fields.
        Activity existingActivity = await ActivityService.GetByIdAsync(Id!.Value);
        _model = new ActivityViewModel
        {
            Id = existingActivity.Id,
            Title = existingActivity.Title,
            DurationMinutes = existingActivity.DurationMinutes
        };

        switch (existingActivity)
        {
            case WorkshopActivity workshop:
                _model.ActivityType = "Workshop";
                _model.InstructorName = workshop.InstructorName;
                _model.MaterialsRequired = workshop.MaterialsRequired;
                break;
            case GameActivity game:
                _model.ActivityType = "Game";
                _model.MinimumAge = game.MinimumAge;
                _model.EquipmentProvided = game.EquipmentProvided;
                break;
            case TalkActivity talk:
                _model.ActivityType = "Talk";
                _model.SpeakerName = talk.SpeakerName;
                _model.Topic = talk.Topic;
                break;
        }
    }

    private async Task SaveAsync()
    {
        _isBusy = true;
        try
        {
            if (IsEdit)
            {
                await ActivityService.UpdateAsync(_model);
                ToastService.ShowSuccess("Activity updated.");
            }
            else
            {
                await ActivityService.CreateAsync(_model);
                ToastService.ShowSuccess("Activity created.");
            }

            Navigation.NavigateTo("admin/activities");
        }
        catch (EventManagementException ex)
        {
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            _isBusy = false;
        }
    }
}
