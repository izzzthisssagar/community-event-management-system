@page "/admin/events"
@attribute [Authorize(Roles = "Admin")]
@inject IEventService EventService
@inject IJSRuntime JS
@inject IToastService ToastService

<PageTitle>Manage Events</PageTitle>

<PageHeader Title="Events" Subtitle="Create, edit and cancel community events.">
    <Actions>
        <a class="btn btn-primary" href="admin/events/create"><Icon Name="plus" Size="16" /> Add event</a>
    </Actions>
</PageHeader>

@if (_events is null)
{
    <SkeletonTable />
}
else if (_events.Count == 0)
{
    <EmptyState IconName="calendar" Message="No events yet. Create your first event.">
        <Action>
            <a class="btn btn-primary" href="admin/events/create"><Icon Name="plus" Size="16" /> Add event</a>
        </Action>
    </EmptyState>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Date</th>
                        <th>Venues</th>
                        <th>Registrations</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Event currentEvent in _events)
                    {
                        <tr>
                            <td class="fw-semibold">@currentEvent.Name</td>
                            <td class="text-nowrap">@currentEvent.Date.ToString("dd MMM yyyy")</td>
                            <td class="small text-muted">@string.Join(", ", currentEvent.Venues.Select(v => v.Name))</td>
                            <td>@currentEvent.Registrations.Count(r => !r.IsCancelled) / @currentEvent.MaxCapacity</td>
                            <td><StatusBadge Status="@(currentEvent.IsCancelled ? "Cancelled" : "Active")" /></td>
                            <td class="text-end text-nowrap">
                                <a class="btn btn-sm btn-outline-secondary" href="admin/events/edit/@currentEvent.Id"><Icon Name="edit" Size="14" /> Edit</a>
                                @if (!currentEvent.IsCancelled)
                                {
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => CancelAsync(currentEvent.Id)"><Icon Name="ban" Size="14" /> Cancel</button>
                                }
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(currentEvent.Id, currentEvent.Name)"><Icon Name="trash" Size="14" /> Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Event>? _events;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _events = await EventService.GetEventsAsync();
    }

    private async Task CancelAsync(Guid guidId)
    {
        // Ask for a reason. prompt returns null if the admin presses cancel, which I treat as "stop".
        string? sReason = await JS.InvokeAsync<string>("prompt", "Please give a reason for cancelling this event:");
        if (string.IsNullOrWhiteSpace(sReason))
        {
            return;
        }

        await EventService.CancelEventAsync(guidId, sReason);
        ToastService.ShowSuccess("The event was cancelled.");
        await LoadAsync();
    }

    private async Task DeleteAsync(Guid guidId, string sName)
    {
        bool bConfirmed = await JS.InvokeAsync<bool>("confirm", $"Delete event '{sName}'? This cannot be undone.");
        if (!bConfirmed)
        {
            return;
        }

        await EventService.DeleteEventAsync(guidId);
        ToastService.ShowSuccess($"Event '{sName}' was deleted.");
        await LoadAsync();
    }
}
