@page "/admin/events"
@attribute [Authorize(Roles = "Admin")]
@inject IEventService EventService
@inject IJSRuntime JS

<PageTitle>Manage Events</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Events</h1>
    <a class="btn btn-primary" href="admin/events/create">Add event</a>
</div>

@if (_events is null)
{
    <p>Loading...</p>
}
else if (_events.Count == 0)
{
    <div class="alert alert-info">No events yet.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Date</th>
                <th>Venues</th>
                <th>Registrations</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (Event currentEvent in _events)
            {
                <tr>
                    <td>@currentEvent.Name</td>
                    <td>@currentEvent.Date.ToString("dd MMM yyyy")</td>
                    <td class="small">@string.Join(", ", currentEvent.Venues.Select(v => v.Name))</td>
                    <td>@currentEvent.Registrations.Count(r => !r.IsCancelled) / @currentEvent.MaxCapacity</td>
                    <td>
                        @if (currentEvent.IsCancelled)
                        {
                            <span class="badge bg-danger">Cancelled</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-secondary" href="admin/events/edit/@currentEvent.Id">Edit</a>
                        @if (!currentEvent.IsCancelled)
                        {
                            <button class="btn btn-sm btn-outline-warning" @onclick="() => CancelAsync(currentEvent.Id)">Cancel</button>
                        }
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(currentEvent.Id, currentEvent.Name)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Event>? _events;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _events = await EventService.GetEventsAsync();
    }

    private async Task CancelAsync(Guid guidId)
    {
        // Ask for a reason. prompt returns null if the admin presses cancel, which I treat as "stop".
        string? sReason = await JS.InvokeAsync<string>("prompt", "Please give a reason for cancelling this event:");
        if (string.IsNullOrWhiteSpace(sReason))
        {
            return;
        }

        await EventService.CancelEventAsync(guidId, sReason);
        await LoadAsync();
    }

    private async Task DeleteAsync(Guid guidId, string sName)
    {
        bool bConfirmed = await JS.InvokeAsync<bool>("confirm", $"Delete event '{sName}'? This cannot be undone.");
        if (!bConfirmed)
        {
            return;
        }

        await EventService.DeleteEventAsync(guidId);
        await LoadAsync();
    }
}
