@page "/admin/participants"
@attribute [Authorize(Roles = "Admin")]
@inject IParticipantService ParticipantService
@inject IJSRuntime JS
@inject IToastService ToastService

<PageTitle>Manage Participants</PageTitle>

<PageHeader Title="Participants" Subtitle="People who can register for events.">
    <Actions>
        <a class="btn btn-primary" href="admin/participants/create"><Icon Name="plus" Size="16" /> Add participant</a>
    </Actions>
</PageHeader>

@if (_participants is null)
{
    <SkeletonTable />
}
else if (_participants.Count == 0)
{
    <EmptyState IconName="users" Message="No participants yet.">
        <Action>
            <a class="btn btn-primary" href="admin/participants/create"><Icon Name="plus" Size="16" /> Add participant</a>
        </Action>
    </EmptyState>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Participant participant in _participants)
                    {
                        <tr>
                            <td class="fw-semibold">@participant.FullName</td>
                            <td>@participant.Email</td>
                            <td>@participant.PhoneNumber</td>
                            <td class="text-end text-nowrap">
                                <a class="btn btn-sm btn-outline-secondary" href="admin/participants/edit/@participant.Id"><Icon Name="edit" Size="14" /> Edit</a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(participant.Id, participant.FullName)"><Icon Name="trash" Size="14" /> Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Participant>? _participants;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _participants = await ParticipantService.GetAllAsync();
    }

    private async Task DeleteAsync(Guid guidId, string sName)
    {
        bool bConfirmed = await JS.InvokeAsync<bool>("confirm", $"Delete participant '{sName}'?");
        if (!bConfirmed)
        {
            return;
        }

        await ParticipantService.DeleteAsync(guidId);
        ToastService.ShowSuccess($"Participant '{sName}' was deleted.");
        await LoadAsync();
    }
}
