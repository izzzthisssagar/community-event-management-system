@page "/admin/venues"
@attribute [Authorize(Roles = "Admin")]
@inject IVenueService VenueService
@inject IJSRuntime JS
@inject IToastService ToastService

<PageTitle>Manage Venues</PageTitle>

<PageHeader Title="Venues" Subtitle="Places where events are held.">
    <Actions>
        <a class="btn btn-primary" href="admin/venues/create"><Icon Name="plus" Size="16" /> Add venue</a>
    </Actions>
</PageHeader>

@if (_venues is null)
{
    <SkeletonTable />
}
else if (_venues.Count == 0)
{
    <EmptyState IconName="map-pin" Message="No venues yet. Add your first venue to get started.">
        <Action>
            <a class="btn btn-primary" href="admin/venues/create"><Icon Name="plus" Size="16" /> Add venue</a>
        </Action>
    </EmptyState>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Address</th>
                        <th>Capacity</th>
                        <th>Accessible</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Venue venue in _venues)
                    {
                        <tr>
                            <td class="fw-semibold">@venue.Name</td>
                            <td>@venue.Address</td>
                            <td>@venue.Capacity</td>
                            <td>@(venue.IsAccessible ? "Yes" : "No")</td>
                            <td class="text-end text-nowrap">
                                <a class="btn btn-sm btn-outline-secondary" href="admin/venues/edit/@venue.Id"><Icon Name="edit" Size="14" /> Edit</a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(venue.Id, venue.Name)"><Icon Name="trash" Size="14" /> Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Venue>? _venues;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _venues = await VenueService.GetAllAsync();
    }

    private async Task DeleteAsync(Guid guidId, string sName)
    {
        // Ask the browser to confirm before I delete, so nothing is removed by accident.
        bool bConfirmed = await JS.InvokeAsync<bool>("confirm", $"Delete venue '{sName}'? This cannot be undone.");
        if (!bConfirmed)
        {
            return;
        }

        await VenueService.DeleteAsync(guidId);
        ToastService.ShowSuccess($"Venue '{sName}' was deleted.");
        await LoadAsync();
    }
}
