@page "/admin/venues"
@attribute [Authorize(Roles = "Admin")]
@inject IVenueService VenueService
@inject IJSRuntime JS

<PageTitle>Manage Venues</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Venues</h1>
    <a class="btn btn-primary" href="admin/venues/create">Add venue</a>
</div>

@if (_venues is null)
{
    <p>Loading...</p>
}
else if (_venues.Count == 0)
{
    <div class="alert alert-info">No venues yet. Click "Add venue" to create one.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Address</th>
                <th>Capacity</th>
                <th>Accessible</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (Venue venue in _venues)
            {
                <tr>
                    <td>@venue.Name</td>
                    <td>@venue.Address</td>
                    <td>@venue.Capacity</td>
                    <td>@(venue.IsAccessible ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" href="admin/venues/edit/@venue.Id">Edit</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(venue.Id, venue.Name)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Venue>? _venues;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _venues = await VenueService.GetAllAsync();
    }

    private async Task DeleteAsync(Guid guidId, string sName)
    {
        // Ask the browser to confirm before I delete, so nothing is removed by accident.
        bool bConfirmed = await JS.InvokeAsync<bool>("confirm", $"Delete venue '{sName}'? This cannot be undone.");
        if (!bConfirmed)
        {
            return;
        }

        await VenueService.DeleteAsync(guidId);
        await LoadAsync();
    }
}
